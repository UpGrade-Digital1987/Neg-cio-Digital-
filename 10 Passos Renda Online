  <script>
    // Default configuration
    const defaultConfig = {
      product_title: 'Método Exclusivo',
      producer_name: 'Alisson Reis',
      price_installment: '3x de R$ 9,64',
      price_full: 'R$ 27,00',
      guarantee_days: '7',
      background_color: '#0f0f23',
      primary_color: '#22c55e',
      text_color: '#ffffff',
      accent_color: '#4ade80',
      secondary_color: '#1f2937',
      font_family: 'Poppins',
      font_size: 16
    };

    // Fake names for purchase popups
    const fakeNames = [
      'Maria S.', 'João P.', 'Ana L.', 'Pedro M.', 'Carla R.',
      'Lucas F.', 'Julia B.', 'Rafael A.', 'Fernanda C.', 'Bruno G.',
      'Camila N.', 'Diego S.', 'Larissa M.', 'Thiago O.', 'Amanda K.'
    ];

    const fakeCities = [
      'São Paulo', 'Rio de Janeiro', 'Belo Horizonte', 'Curitiba', 'Porto Alegre',
      'Salvador', 'Brasília', 'Fortaleza', 'Recife', 'Manaus'
    ];

    // Show purchase popup
    function showPurchasePopup() {
      const popup = document.getElementById('purchase-popup');
      const nameEl = document.getElementById('popup-name');
      
      const randomName = fakeNames[Math.floor(Math.random() * fakeNames.length)];
      const randomCity = fakeCities[Math.floor(Math.random() * fakeCities.length)];
      
      nameEl.textContent = `${randomName} de ${randomCity}`;
      
      popup.classList.remove('hidden');
      
      setTimeout(() => {
        popup.classList.add('hidden');
      }, 4000);
    }

    // Show bottom banner after scroll
    function handleScroll() {
      const banner = document.getElementById('bottom-banner');
      const scrollPosition = window.scrollY || document.documentElement.scrollTop;
      
      if (scrollPosition > 500) {
        banner.classList.remove('hidden');
      }
    }

    // Initialize popups and banners
    function initMarketingElements() {
      // Show first popup after 5 seconds
      setTimeout(showPurchasePopup, 5000);
      
      // Show popups randomly every 15-30 seconds
      setInterval(() => {
        if (Math.random() > 0.3) {
          showPurchasePopup();
        }
      }, Math.random() * 15000 + 15000);
      
      // Listen for scroll
      const appWrapper = document.getElementById('app-wrapper');
      appWrapper.addEventListener('scroll', function() {
        const banner = document.getElementById('bottom-banner');
        if (this.scrollTop > 500) {
          banner.classList.remove('hidden');
        }
      });
    }

    // Config change handler
    async function onConfigChange(config) {
      const title = document.getElementById('main-title');
      if (title) {
        title.innerHTML = `Transforme Sua Vida com o <span class="text-gradient">${config.product_title || defaultConfig.product_title}</span>`;
      }
      
      const producerName = document.getElementById('producer-name');
      if (producerName) {
        producerName.textContent = config.producer_name || defaultConfig.producer_name;
      }
      
      const priceInstallment = document.getElementById('price-installment');
      if (priceInstallment) {
        const installment = config.price_installment || defaultConfig.price_installment;
        priceInstallment.innerHTML = installment.replace(/R\$\s*[\d,]+/g, '<span class="text-green-400">$&</span>');
      }
      
      const priceFull = document.getElementById('price-full');
      if (priceFull) {
        priceFull.textContent = config.price_full || defaultConfig.price_full;
      }
      
      const guaranteeDays = document.getElementById('guarantee-days');
      if (guaranteeDays) {
        guaranteeDays.textContent = `${config.guarantee_days || defaultConfig.guarantee_days} Dias`;
      }

      // Apply colors
      const primaryColor = config.primary_color || defaultConfig.primary_color;
      const accentColor = config.accent_color || defaultConfig.accent_color;
      
      document.querySelectorAll('.text-green-400').forEach(el => {
        el.style.color = primaryColor;
      });
      
      document.querySelectorAll('.text-gradient').forEach(el => {
        el.style.background = `linear-gradient(90deg, ${primaryColor}, ${accentColor})`;
        el.style.webkitBackgroundClip = 'text';
        el.style.webkitTextFillColor = 'transparent';
        el.style.backgroundClip = 'text';
      });

      // Apply font
      const fontFamily = config.font_family || defaultConfig.font_family;
      document.body.style.fontFamily = `${fontFamily}, sans-serif`;

      // Apply font size
      const baseSize = config.font_size || defaultConfig.font_size;
      document.body.style.fontSize = `${baseSize}px`;
    }

    // Map to capabilities
    function mapToCapabilities(config) {
      return {
        recolorables: [
          {
            get: () => config.background_color || defaultConfig.background_color,
            set: (value) => {
              config.background_color = value;
              window.elementSdk.setConfig({ background_color: value });
            }
          },
          {
            get: () => config.secondary_color || defaultConfig.secondary_color,
            set: (value) => {
              config.secondary_color = value;
              window.elementSdk.setConfig({ secondary_color: value });
            }
          },
          {
            get: () => config.text_color || defaultConfig.text_color,
            set: (value) => {
              config.text_color = value;
              window.elementSdk.setConfig({ text_color: value });
            }
          },
          {
            get: () => config.primary_color || defaultConfig.primary_color,
            set: (value) => {
              config.primary_color = value;
              window.elementSdk.setConfig({ primary_color: value });
            }
          },
          {
            get: () => config.accent_color || defaultConfig.accent_color,
            set: (value) => {
              config.accent_color = value;
              window.elementSdk.setConfig({ accent_color: value });
            }
          }
        ],
        borderables: [],
        fontEditable: {
          get: () => config.font_family || defaultConfig.font_family,
          set: (value) => {
            config.font_family = value;
            window.elementSdk.setConfig({ font_family: value });
          }
        },
        fontSizeable: {
          get: () => config.font_size || defaultConfig.font_size,
          set: (value) => {
            config.font_size = value;
            window.elementSdk.setConfig({ font_size: value });
          }
        }
      };
    }

    // Map to edit panel values
    function mapToEditPanelValues(config) {
      return new Map([
        ['product_title', config.product_title || defaultConfig.product_title],
        ['producer_name', config.producer_name || defaultConfig.producer_name],
        ['price_installment', config.price_installment || defaultConfig.price_installment],
        ['price_full', config.price_full || defaultConfig.price_full],
        ['guarantee_days', config.guarantee_days || defaultConfig.guarantee_days]
      ]);
    }

    // Initialize SDK
    if (window.elementSdk) {
      window.elementSdk.init({
        defaultConfig,
        onConfigChange,
        mapToCapabilities,
        mapToEditPanelValues
      });
    }

    // Initialize marketing elements
